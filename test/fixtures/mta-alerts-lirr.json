    "description_text": {
     "translation": [
      {
       "text": "MTA buses will accept LIRR tickets for travel from Queens Village and Hollis to Jamaica. View a map of your route options.\n\nElmont-UBS Arena riders should use Bellerose station instead.\n\nFollow this link for information about transferring at the Jamaica Bus Terminal.\n\nWhat's happening?\nAccessibility improvements",
       "language": "en"
      },
