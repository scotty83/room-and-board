      {
       "text": "No eastbound service at Forest Hills and Kew Gardens. Eastbound trains towards Jamaica bypass Woodside",
       "language": "en"
      },
      {
       "text": "<p>No eastbound service at <strong>Forest Hills</strong> and <strong>Kew Gardens</strong>. Eastbound trains towards <strong>Jamaica</strong> bypass <strong>Woodside</strong></p>",
       "language": "en-html"
